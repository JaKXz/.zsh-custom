// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "cli_default_open_behavior": "new_window",
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "language_models": {
    "ollama": {
      "api_url": "http://127.0.0.1:11434/"
    }
  },
  "proxy": "",
  "debugger": {
    "dock": "left"
  },
  "calls": {
    "mute_on_join": true
  },
  "tab_size": 2,
  "vertical_scroll_margin": 10.0,
  "theme": {
    "mode": "system",
    "light": "Night Owl Dark",
    "dark": "Tokyo Night"
  },
  "prettier": {
    "allowed": false,
  },
  "show_edit_predictions": true,
  "base_keymap": "JetBrains",
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "edit_predictions": {
    "provider": "none",
    "disabled_globs": [],
    "mode": "subtle",
    "copilot": {
      "enable_next_edit_suggestions": false,
      "proxy": null,
      "proxy_no_verify": null,
      "enterprise_uri": null,
    },
  },
  "file_types": {
    "GitHub Actions": [
      ".github/**/*.yml",
      ".github/**/*.yaml"
    ],
  },
  "title_bar": {
    "show_branch_name": true, // Show/hide branch name
    "show_project_items": true, // Show/hide project host and name
    "show_onboarding_banner": false, // Show/hide onboarding banners
    "show_user_picture": false, // Show/hide user avatar
    "show_sign_in": false, // Show/hide sign-in button
    "show_menus": true, // Show/hide menus
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-opus-4.6",
        "enable_thinking": true
      },
    ],
    "dock": "right",
    "default_profile": "write",
    "default_model": {
      "effort": "high",
      "enable_thinking": true,
      "provider": "copilot_chat",
      "model": "gpt-5.4",
    },
  },
  "project_panel": {
    "dock": "right",
  },
  "indent_guides": {
    "line_width": 1,
    "active_line_width": 2,
    "coloring": "indent_aware",
    "background_coloring": "indent_aware",
  },
  // "ui_font_size": 17,
  // "buffer_font_size": 17,
  // "buffer_font_family": "Monaspace Neon",
  "buffer_font_features": {
    "liga": true,
    "calt": true,
    "ss01": true,
    "ss02": true,
    "ss03": true,
    "ss04": true,
    "ss05": true,
    "ss06": true,
    "ss07": true,
    "ss08": true,
    "ss09": true,
    "ss10": true,
    "ss11": true,
    "ss12": true,
  },
  "terminal": {
    "font_family": "JetBrainsMono Nerd Font",
  },
  // "load_direnv": "shell_hook",
  "lsp": {
    // "rust-analyzer": {
    //   "initialization_options": {
    //     // "cargo": {},
    //     "check": {
    //       "overrideCommand": [
    //         "./tools/with-wasm-env",
    //         "cargo",
    //         "clippy",
    //         "--target=wasm32-unknown-unknown",
    //         // "--features",
    //         // "item-details,masked-email,totp,brex,b5x",
    //         "--all-features",
    //         "--message-format=json",
    //         "-p",
    //         "op-wasm-b5x"
    //       ]
    //     }
    //   }
    // },
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "customTags": [
            "!reference sequence"
          ],
        },
      },
    },
  },
}
